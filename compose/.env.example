# Connection settings
HERMES_PG_USER=hermes
HERMES_PG_PASSWORD=changeme
HERMES_TEMPLATE_DB=hermes_template

# Embedding (Kimi bge_m3_embed is the free default)
KIMI_API_KEY=
# OLLAMA_API_KEY=       # only if you switch to ollama_local

# Optional: per-dim overrides
# HERMES_EMBED_PROVIDER_768=ollama_local
# HERMES_EMBED_PROVIDER_1024=kimi
# HERMES_EMBED_PROVIDER_1536=openai
# HERMES_EMBED_API_KEY_OPENAI=

# Embedding cache (per-dim). Defaults to ~/.cache/hermes/embeddings/<dim>
# HERMES_EMBED_CACHE_DIR_1024=/var/cache/hermes/embeddings/1024

# Fail-open on embedder errors (1 = keep storing with zero vector, 0 = raise)
# HERMES_EMBED_FAIL_OPEN=1
