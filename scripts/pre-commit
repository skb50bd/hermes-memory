#!/bin/bash
#
# .git/hooks/pre-commit
#
# Lint every staged file in the project before allowing the commit.
# Detects file type, dispatches to the right linter, blocks the commit
# if any linter reports a problem.
#
# Per dev-standards: "Every repo MUST have a pre-commit hook that lints
# every file in the project." Implemented as: for each file in `git
# diff --cached --name-only --diff-filter=ACMR`, run the linter that
# matches the file's extension, and abort the commit on non-zero exit.
#
# To bypass in an emergency: git commit --no-verify
#
# To install on a fresh clone:
#   install -m 0755 scripts/pre-commit .git/hooks/pre-commit
#
# Linters (must be on PATH):
#   ruff    - Python linter (also called via rtk)
#   rtk     - Rust Token Killer; runs ruff under the hood
#
# File-type dispatch:
#   *.py        → ruff check
#   *.sh        → shellcheck
#   *.yaml,*.yml → yamllint (or python3 yaml.safe_load fallback)
#   *.json      → python3 -m json.tool
#   *.sql       → non-empty check; full validation in CI integration tests
#   Dockerfile  → hadolint if available, else no-op
#   *           → no-op (unrecognized file type)
#
# New files (untracked) are NOT linted here — they aren't in the diff.
# Run the lint suite manually before staging a new file.

set -e

# Colors for the warnings
printf -v RED '\033[0;31m'
printf -v YEL '\033[0;33m'
printf -v GRN '\033[0;32m'
printf -v RST '\033[0m'

cd "$(git rev-parse --show-toplevel)"

# Always run `ruff format --check` over the whole project, not just
# staged files. Formatting drift across unstaged files is a common
# source of CI failures (the CI lint job runs `ruff format --check`
# and a single unformatted file fails the whole job).
if command -v ruff >/dev/null 2>&1; then
    if ! ruff format --check src/ tests/ 2>&1; then
        echo "${RED}pre-commit: ruff format --check failed${RST}"
        echo "${YEL}Run: ruff format src/ tests/${RST}"
        exit 1
    fi
fi

# Find staged files (added/copied/modified/renamed, not deleted).
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$STAGED" ]; then
    exit 0
fi

FAILED=0
LINTED=0

for path in $STAGED; do
    # Skip files outside the working tree (e.g. deleted but listed somehow)
    [ -f "$path" ] || continue

    case "$path" in
        *.py)
            LINTED=$((LINTED+1))
            # Use ruff directly when available. rtk is a token-saving
            # wrapper around ruff but its output filtering can hide
            # F401 unused-import errors. Run ruff in --no-fix mode so
            # it doesn't modify staged files.
            if command -v ruff >/dev/null 2>&1; then
                if ! ruff check --no-fix --output-format=concise "$path"; then
                    echo "${RED}pre-commit: ruff failed for $path${RST}"
                    FAILED=$((FAILED+1))
                fi
            elif command -v rtk >/dev/null 2>&1; then
                if ! rtk ruff check "$path"; then
                    echo "${RED}pre-commit: rtk ruff failed for $path${RST}"
                    FAILED=$((FAILED+1))
                fi
            else
                echo "${YEL}pre-commit: skip Python lint for $path (no ruff/rtk)${RST}"
            fi
            ;;
        *.sh)
            LINTED=$((LINTED+1))
            if command -v shellcheck >/dev/null 2>&1; then
                if ! shellcheck "$path"; then
                    echo "${RED}pre-commit: shellcheck failed for $path${RST}"
                    FAILED=$((FAILED+1))
                fi
            else
                echo "${YEL}pre-commit: skip shellcheck for $path (not installed)${RST}"
            fi
            ;;
        *.yaml|*.yml)
            LINTED=$((LINTED+1))
            if command -v yamllint >/dev/null 2>&1; then
                if ! yamllint -d relaxed "$path" 2>&1; then
                    echo "${RED}pre-commit: yamllint failed for $path${RST}"
                    FAILED=$((FAILED+1))
                fi
            elif command -v python3 >/dev/null 2>&1; then
                # Fallback: at least verify it's parseable YAML
                if ! python3 -c "import sys, yaml; yaml.safe_load(open(sys.argv[1]))" "$path" 2>&1; then
                    echo "${RED}pre-commit: YAML parse failed for $path${RST}"
                    FAILED=$((FAILED+1))
                fi
            fi
            ;;
        *.json)
            LINTED=$((LINTED+1))
            if ! python3 -m json.tool "$path" >/dev/null 2>&1; then
                echo "${RED}pre-commit: JSON parse failed for $path${RST}"
                FAILED=$((FAILED+1))
            fi
            ;;
        *.sql)
            LINTED=$((LINTED+1))
            # No lightweight SQL linter on the dev box. Just verify the
            # file is at least readable + non-empty. Full SQL validation
            # happens via the integration tests in CI.
            if [ ! -s "$path" ]; then
                echo "${RED}pre-commit: empty SQL file $path${RST}"
                FAILED=$((FAILED+1))
            fi
            ;;
        Dockerfile|*.dockerfile|Dockerfile.*)
            LINTED=$((LINTED+1))
            if command -v hadolint >/dev/null 2>&1; then
                if ! hadolint "$path" 2>&1; then
                    echo "${RED}pre-commit: hadolint failed for $path${RST}"
                    FAILED=$((FAILED+1))
                fi
            else
                echo "${YEL}pre-commit: skip hadolint for $path (not installed)${RST}"
            fi
            ;;
        *.md)
            # No-op for markdown; rendered text, no syntax to lint.
            ;;
        *)
            # Unrecognized file type — no-op. We don't want to fail
            # commits because of binaries, images, lock files, etc.
            ;;
    esac
done

if [ "$FAILED" -gt 0 ]; then
    echo "${RED}pre-commit: $FAILED linter(s) failed across $LINTED file(s). Commit aborted.${RST}"
    echo "${YEL}Bypass with: git commit --no-verify${RST}"
    exit 1
fi

if [ "$LINTED" -gt 0 ]; then
    echo "${GRN}pre-commit: $LINTED file(s) linted, all passed.${RST}"
fi

exit 0
